{
  "DIMENSIONS": {
    "MIN_HEIGHT": 1440,
    "MIN_WIDTH": 2560
  },
  "RATIO": {
    "RATIO_HEIGHT": 16,
    "RATIO_WIDTH": 9,
    "TOLERANCE": 0.01
  },
  "DRY_RUN": true,
  "OUTPUT_PATH": "./output.txt",
  "RETRY_COUNT": 3,
  "RETRY_DELAY": 1000,
  "IMAGE_PATTERNS": [
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.png",
    "**/*.webp",
    "**/*.avif",
    "**/*.tif",
    "**/*.tiff",
    "**/*.gif",
    "**/*.bmp",
    "**/*.heic"
  ],
  "ALLOWED_DIRECTORIES": [
    "./",
    "./images",
    "./photos",
    "./pictures",
    "./downloads/images",
    "./media"
  ],
  "RESTRICT_TO_IMAGES_FOLDER": true
}
